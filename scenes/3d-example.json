{
  "name": "Example Scene",
  "type": "3d",
  "camera": {
    "position": { "x": 5, "y": 5, "z": 5 },
    "lookAt": { "x": 0, "y": 0, "z": 0 }
  },
  "objects": [
    {
      "type": "box",
      "name": "Ground",
      "position": { "x": 0, "y": 0, "z": 0 },
      "rotation": { "x": 0, "y": 0, "z": 0 },
      "scale": { "x": 10, "y": 0.5, "z": 10 },
      "color": "#2c3e50",
      "castShadow": false,
      "receiveShadow": true
    },
    {
      "type": "sphere",
      "name": "Bouncing Ball",
      "position": { "x": 0, "y": 2, "z": 0 },
      "rotation": { "x": 0, "y": 0, "z": 0 },
      "scale": { "x": 1, "y": 1, "z": 1 },
      "color": "#e74c3c",
      "castShadow": true,
      "receiveShadow": true,
      "animation": {
        "code": "if (!this.userData.bounceTime) this.userData.bounceTime = 0; this.userData.bounceTime += 0.05; this.mesh.position.y = 2 + Math.abs(Math.sin(this.userData.bounceTime)) * 2; this.mesh.rotation.x += 0.05; this.mesh.rotation.z += 0.03;"
      }
    },
    {
      "type": "box",
      "name": "Spinning Cube",
      "position": { "x": -2, "y": 1, "z": 2 },
      "rotation": { "x": 0, "y": 45, "z": 0 },
      "scale": { "x": 1, "y": 1, "z": 1 },
      "color": "#3498db",
      "castShadow": true,
      "receiveShadow": true,
      "animation": {
        "code": "this.mesh.rotation.y += 0.02; this.mesh.rotation.x += 0.01; const scale = 1 + Math.sin(Date.now() * 0.002) * 0.2; this.mesh.scale.set(scale, scale, scale);"
      }
    },
    {
      "type": "cylinder",
      "name": "Orbiting Pillar",
      "position": { "x": 3, "y": 1.5, "z": -1 },
      "rotation": { "x": 0, "y": 0, "z": 0 },
      "scale": { "x": 0.5, "y": 3, "z": 0.5 },
      "color": "#9b59b6",
      "castShadow": true,
      "receiveShadow": true,
      "animation": {
        "code": "const time = Date.now() * 0.001; const radius = 3; this.mesh.position.x = Math.cos(time) * radius; this.mesh.position.z = Math.sin(time) * radius; this.mesh.rotation.y += 0.03;"
      }
    },
    {
      "type": "torus",
      "name": "Floating Torus",
      "position": { "x": -3, "y": 2, "z": -2 },
      "rotation": { "x": 45, "y": 0, "z": 0 },
      "scale": { "x": 0.8, "y": 0.8, "z": 0.8 },
      "color": "#f39c12",
      "castShadow": true,
      "receiveShadow": true,
      "animation": {
        "code": "this.mesh.rotation.x += 0.02; this.mesh.rotation.y += 0.03; this.mesh.position.y = 2 + Math.sin(Date.now() * 0.002) * 0.5;"
      }
    },
    {
      "type": "cone",
      "name": "Pulsing Cone",
      "position": { "x": 2, "y": 1, "z": 3 },
      "rotation": { "x": 0, "y": 0, "z": 0 },
      "scale": { "x": 0.7, "y": 1.5, "z": 0.7 },
      "color": "#1abc9c",
      "castShadow": true,
      "receiveShadow": true,
      "animation": {
        "code": "const pulse = Math.sin(Date.now() * 0.003) * 0.3 + 1; this.mesh.scale.set(0.7 * pulse, 1.5, 0.7 * pulse); this.mesh.rotation.y += 0.02;"
      }
    }
  ],
  "lights": [
    {
      "type": "ambient",
      "name": "Ambient Light",
      "color": "#404040",
      "intensity": 0.5
    },
    {
      "type": "directional",
      "name": "Sun",
      "color": "#ffffff",
      "intensity": 1,
      "position": { "x": 5, "y": 10, "z": 5 },
      "castShadow": true
    },
    {
      "type": "point",
      "name": "Accent Light",
      "color": "#ff00ff",
      "intensity": 0.5,
      "position": { "x": -3, "y": 3, "z": 3 },
      "distance": 10
    }
  ]
}
